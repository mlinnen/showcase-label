<Window x:Class="ShowcaseLabel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ShowcaseLabel"
        mc:Ignorable="d"
        Title="Showcase Label Printer" Height="350" Width="450" WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Carver ID:" VerticalAlignment="Center" Margin="0,0,10,10"/>
        <TextBox x:Name="CarverIdTextBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,10" Padding="5"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Total Entries:" VerticalAlignment="Center" Margin="0,0,10,10"/>
        <TextBox x:Name="TotalEntriesTextBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,10" Padding="5" Text="1"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Printer:" VerticalAlignment="Center" Margin="0,0,10,10"/>
        <ComboBox x:Name="PrinterComboBox" Grid.Row="2" Grid.Column="1" Margin="0,0,0,10" Padding="5"/>

        <Button x:Name="PrintButton" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Content="Print Labels" 
                Click="PrintButton_Click" Padding="10" Margin="0,10,0,10" Background="#007ACC" Foreground="White" FontWeight="Bold"/>

        <TextBlock x:Name="StatusTextBlock" Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Text="Ready" Foreground="Gray" Margin="0,10,0,0"/>
    </Grid>
</Window>
